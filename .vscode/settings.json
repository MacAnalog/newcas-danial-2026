{
  // ---------------------------------------------------------------------------
  // FOLDER-LEVEL settings for the "newcas-danial-2026" box.
  // These OVERRIDE the shared settings in ../sandbox.code-workspace for this
  // folder only. Precedence: User < Workspace (.code-workspace) < this file.
  // Only put things here that should differ from the workspace defaults.
  // ---------------------------------------------------------------------------

  // Pin this box's interpreter explicitly (handy if auto-detection ever fails).
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // uv-managed venv has no pip; tell the Python Envs extension to use uv instead.
  "ms-python.python-envs.alwaysUseUv": true,

  // This box is conference demo code — keep type checking relaxed here even if
  // the workspace default is stricter.
  "python.analysis.typeCheckingMode": "basic",

  // Treat the plotting script's output dir + data as read-mostly: hide them.
  "files.exclude": {
    "**/__pycache__": true,
    "**/.ipynb_checkpoints": true
  },

  // Example: a per-folder editor tweak (wider ruler for the plotting code).
  "editor.rulers": [100]
}
